  doi = {10.48550/arXiv.math/0409186},
  url = {http://arxiv.org/abs/math/0409186},
  urldate = {2026-03-30},
  abstract = {This paper considers the model problem of reconstructing an object from incomplete frequency samples. Consider a discrete-time signal \$f \textbackslash in \textbackslash C\textasciicircum N\$ and a randomly chosen set of frequencies \$\textohm\$ of mean size \${$\tau$}N\$. Is it possible to reconstruct \$f\$ from the partial knowledge of its Fourier coefficients on the set \$\textohm\$? A typical result of this paper is as follows: for each \$M {$>$} 0\$, suppose that \$f\$ obeys \$\$ \# \textbackslash\textbraceleft t, f(t) \textbackslash neq 0 \textbackslash\textbraceright{} \textbackslash le {$\alpha$}(M) \textbackslash cdot (\textbackslash log N)\textasciicircum\textbraceleft -1\textbraceright{} \textbackslash cdot \# \textohm, \$\$ then with probability at least \$1-O(N\textasciicircum\textbraceleft -M\textbraceright )\$, \$f\$ can be reconstructed exactly as the solution to the \$\textbackslash ell\_1\$ minimization problem \$\$ \textbackslash min\_g \textbackslash sum\_\textbraceleft t = 0\textbraceright\textasciicircum\textbraceleft N-1\textbraceright{} \textbar g(t)\textbar, \textbackslash quad \textbackslash text\textbraceleft s.t.\textbraceright{} \textbackslash hat g({$\omega$}) = \textbackslash hat f({$\omega$}) \textbackslash text\textbraceleft for all\textbraceright{} {$\omega\backslash$}in \textohm. \$\$ In short, exact recovery may be obtained by solving a convex optimization problem. We give numerical values for \${$\alpha\$$} which depends on the desired probability of success; except for the logarithmic factor, the condition on the size of the support is sharp. The methodology extends to a variety of other setups and higher dimensions. For example, we show how one can reconstruct a piecewise constant (one or two-dimensional) object from incomplete frequency samples--provided that the number of jumps (discontinuities) obeys the condition above--by minimizing other convex functionals such as the total-variation of \$f\$.},
  archiveprefix = {arXiv},
  keywords = {Mathematics - Classical Analysis and ODEs,Mathematics - Numerical Analysis},
  file = {/Users/julianschulz/Zotero/storage/54V84FT4/Candes et al. - 2004 - Robust Uncertainty Principles Exact Signal Reconstruction from Highly Incomplete Frequency Informat.pdf;/Users/julianschulz/Zotero/storage/L3VYAD83/0409186.html}
}

