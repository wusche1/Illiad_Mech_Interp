  shorttitle = {Inference-{{Time Intervention}}},
  author = {Li, Kenneth and Patel, Oam and Vi{\'e}gas, Fernanda and Pfister, Hanspeter and Wattenberg, Martin},
  year = 2024,
  month = jun,
  number = {arXiv:2306.03341},
